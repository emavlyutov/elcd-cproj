#==============================================================================
# elAPI/Makefile - ElCyberDev API build configuration
#==============================================================================
# Aggregates HAL, elRTOS, elCrypto sources and defines. Conditionally includes
# sub-Makefiles based on CONFIG_ELAPI_HAL_EN, CONFIG_ELAPI_ELRTOS_EN, etc.
# Defines: OS_ELRTOS_EN, OS_ELRTOS_IRQ_MANAGED, CONFIG_ELAPI_HAL_*
#==============================================================================

ELAPISRCS:=
ELAPIOBJS:=
ELAPILIBS:=
ELAPIINCFLAGS:=
ELAPIDEFFLAGS:=
ELAPILIBFLAGS:=

ELAPIINCFLAGS+ = \
        -I"$(ELAPIDIR)" \
        -I"$(ELAPIDIR)elUtils" \
        -I"$(ELAPIDIR)elSyslog"

ifeq ($(CONFIG_ELAPI_HAL_EN),y)
    ELHALDIR=$(ELAPIDIR)elHAL/
    -include $(ELHALDIR)Makefile
    ELAPISRCS+= $(ELHALSOURCES)
    ELAPIOBJS+= $(ELHALOBJS)
    ELAPILIBS+= $(ELHALLIBS)
    ELAPIINCFLAGS+= $(ELHALINCFLAGS)
    ELAPIDEFFLAGS+= $(ELHALDEFFLAGS)
    ELAPILIBFLAGS+= $(ELHALLIBFLAGS)
endif

ifeq ($(CONFIG_ELAPI_ELRTOS_EN),y)
    ELRTOSDIR=$(ELAPIDIR)elRTOS/
    -include $(ELRTOSDIR)Makefile
    ELAPISRCS+= $(ELRTOSSOURCES)
    ELAPIOBJS+= $(ELRTOSOBJS)
    ELAPILIBS+= $(ELRTOSLIBS)
    ELAPIINCFLAGS+= $(ELRTOSINCFLAGS)
    ELAPIDEFFLAGS+= $(ELRTOSDEFFLAGS)
    ELAPILIBFLAGS+= $(ELRTOSLIBFLAGS)
endif

ifeq ($(CONFIG_ELAPI_CLI_EN),y)
    ELRTOSDIR=$(ELAPIDIR)elCLI/
    -include $(ELRTOSDIR)Makefile
    ELAPISRCS+= $(ELRTOSSRCS)
    ELAPIOBJS+= $(ELRTOSOBJS)
    ELAPILIBS+= $(ELRTOSLIBS)
    ELAPIINCFLAGS+= $(ELRTOSINCFLAGS)
    ELAPIDEFFLAGS+= $(ELRTOSDEFFLAGS)
    ELAPILIBFLAGS+= $(ELRTOSLIBFLAGS)
endif

ifeq ($(CONFIG_ELAPI_ELCRYPTO_EN),y)
    ELCRYPTODIR=$(ELAPIDIR)elCrypto/
    -include $(ELCRYPTODIR)Makefile
    ELAPISRCS+= $(ELCRYPTOSRCS)
    ELAPIOBJS+= $(ELCRYPTOOBJS)
    ELAPILIBS+= $(ELCRYPTOLIBS)
    ELAPIINCFLAGS+= $(ELCRYPTOINCFLAGS)
    ELAPIDEFFLAGS+= $(ELCRYPTODEFFLAGS)
    ELAPILIBFLAGS+= $(ELCRYPTOLIBFLAGS)
endif

ifdef (__BUILD_AS_LIB__)
ifneq (,$(ELAPIOBJS))

ELAPILIBNAME:=elapi
ELAPILIBOBJS:= $(ELAPIOBJS)
ELAPILIBFLAGS+= -L"$(ELAPIDIR)"
ELAPILIBPATH:=$(ELAPIDIR)$(ELAPILIBNAME).a
ELAPILIBS+= $(ELAPILIBPATH)
ELAPIOBJS:=

.PHONY: $(ELAPILIBNAME)
$(ELAPILIBPATH): $(ELAPILIBOBJS)
	@echo "Building library $(ELAPILIBNAME)"
	@$(GCC_AR) $(ELAPILIBOBJS) -o "$@" 
	@echo "Done"

.PHONY: clean_$(ELAPILIBNAME)
clean_$(ELAPILIBNAME):
	$(call RM,$(ELAPILIBPATH))

EXTRA_CLEAN+= clean_$(ELAPILIBNAME)

endif
endif
